# .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/

# Model weights (too large for git)
*.pt
*.pth
*.bin
*.safetensors
*.gguf

# Generated data (use Git LFS or external storage)
data/synthetic_clips/
data/annotated/
data/annotations/
data/training/
data/train.json
datagen/site_photos/*.jpg
datagen/site_photos/*.png
evaluation/results/*.json

# Dashboard
dashboard/node_modules/
dashboard/.next/
dashboard/out/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local

# Logs
*.log
logs/
