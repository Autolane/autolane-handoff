# GCP Configuration
GCP_PROJECT_ID=autolane-handoff-20260221
GCP_REGION=us-central1

# Vertex AI Configuration (set after deployment)
VERTEX_ENDPOINT_ID=
VERTEX_MODEL_ID=

# Model Configuration
MODEL_NAME=nvidia/Cosmos-Reason2-8B

# Deployment Configuration
MACHINE_TYPE=a2-highgpu-1g
ACCELERATOR_TYPE=NVIDIA_TESLA_A100
ACCELERATOR_COUNT=1
MIN_REPLICAS=1
MAX_REPLICAS=1

# vLLM Configuration
MAX_MODEL_LEN=16384
GPU_MEMORY_UTILIZATION=0.90
TENSOR_PARALLEL_SIZE=1
DTYPE=bfloat16

# Inference Configuration
TEMPERATURE=0.2
MAX_TOKENS=4096
VIDEO_FPS=4

# Fine-tuned Model Configuration (Phase 3+)
USE_FINETUNED_MODEL=false
FINETUNED_MODEL_GCS_URI=

# Hugging Face (for gated model access)
HF_TOKEN=

# Datagen — Cosmos Predict 2.5 on Vertex AI
DATAGEN_MODE=image2world
DATAGEN_GCS_BUCKET=autolane-handoff-datagen
DATAGEN_MODEL_NAME=nvidia/Cosmos-Predict2.5-14B
DATAGEN_NUM_INFERENCE_STEPS=36
DATAGEN_SEED=42
DATAGEN_NUM_SEEDS=1
DATAGEN_USE_MODEL_CACHE=true
# DATAGEN_PROMPT_IDS=i2w_tesla_model_y_loading,i2w_humanoid_tesla_model_3
